{
  "acp": {
    "allowedAgents": [
      "claude"
    ],
    "backend": "acpx",
    "defaultAgent": "claude",
    "enabled": true,
    "maxConcurrentSessions": 4,
    "runtime": {
      "ttlMinutes": 180
    }
  },
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "model": {
        "primary": "ikuncode-codex/gpt-5.3-codex"
      },
      "models": {
        "ikuncode-codex/gpt-5.2": {},
        "ikuncode-codex/gpt-5.2-codex": {},
        "ikuncode-codex/gpt-5.3-codex": {
          "params": {
            "maxTokens": 1024
          },
          "streaming": false
        }
      },
      "sandbox": {
        "docker": {
          "binds": [],
          "env": {
            "GH_CONFIG_DIR": "/root/.config/gh",
            "npm_config_nodedir": "/usr"
          },
          "image": "openclaw-sandbox:ubuntu-24.04-full",
          "network": "bridge",
          "readOnlyRoot": false,
          "setupCommand": "(git config --global credential.https://github.com.helper \"!gh auth git-credential\" || true) && (sudo -n true >/dev/null 2>&1 || (printf \"#!/usr/bin/env bash\\nexec \\\"\\$@\\\"\\n\" > /usr/local/bin/sudo && chmod +x /usr/local/bin/sudo))",
          "user": "0:0",
          "workdir": "/workspace"
        },
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw"
      },
      "subagents": {
        "archiveAfterMinutes": 240,
        "maxChildrenPerAgent": 6,
        "maxConcurrent": 8,
        "maxSpawnDepth": 2,
        "runTimeoutSeconds": 1800
      },
      "workspace": "/home/suguan/openclaw-workspace"
    },
    "list": [
      {
        "agentDir": "~/.openclaw/agents/main/agent",
        "default": true,
        "id": "main",
        "name": "Main Agent",
        "workspace": "${OPENCLAW_WORKSPACE_ROOT}"
      },
      {
        "agentDir": "~/.openclaw/agents/research-lead/agent",
        "groupChat": {
          "mentionPatterns": [
            "@manager\b",
            "@lead\b",
            "@engineer\b",
            "@researcher\b",
            "@reporter\b",
            "@tracker\b"
          ]
        },
        "id": "research-lead",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "name": "Research Lead",
        "sandbox": {
          "mode": "off"
        },
        "subagents": {
          "allowAgents": [
            "engineer",
            "reporter",
            "researcher",
            "tracker"
          ]
        },
        "tools": {
          "deny": [
            "exec"
          ]
        },
        "workspace": "~/.openclaw/workspace-research-lead"
      },
      {
        "agentDir": "~/.openclaw/agents/researcher/agent",
        "id": "researcher",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "name": "Researcher",
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw"
        },
        "workspace": "~/.openclaw/workspace-researcher"
      },
      {
        "agentDir": "~/.openclaw/agents/engineer/agent",
        "id": "engineer",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "name": "Engineer",
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw"
        },
        "workspace": "~/.openclaw/workspace-engineer"
      },
      {
        "agentDir": "~/.openclaw/agents/reporter/agent",
        "id": "reporter",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "name": "Reporter",
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw"
        },
        "tools": {
          "deny": [
            "exec"
          ]
        },
        "workspace": "~/.openclaw/workspace-reporter"
      },
      {
        "agentDir": "~/.openclaw/agents/tracker/agent",
        "id": "tracker",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "name": "Tracker",
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw"
        },
        "tools": {
          "deny": [
            "exec"
          ]
        },
        "workspace": "~/.openclaw/workspace-tracker"
      }
    ]
  },
  "bindings": [
    {
      "agentId": "research-lead",
      "match": {
        "accountId": "manager",
        "channel": "discord",
        "peer": {
          "id": "565501941510045707",
          "kind": "channel"
        }
