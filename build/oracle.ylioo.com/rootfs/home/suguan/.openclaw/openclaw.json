{
  "logging": {
    "level": "trace",
    "consoleLevel": "debug",
    "consoleStyle": "pretty"
  },
  "browser": {
    "enabled": true,
    "executablePath": "/home/suguan/.openclaw/tools/playwright-browsers/chromium-1208/chrome-linux/chrome",
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "defaultAgent": "codex",
    "allowedAgents": [
      "codex"
    ],
    "maxConcurrentSessions": 4,
    "runtime": {
      "ttlMinutes": 180
    }
  },
  "models": {
    "providers": {
      "ikuncode-codex": {
        "baseUrl": "${OPENAI_BASE_URL}",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-responses",
        "headers": {
          "User-Agent": "Mozilla/5.0"
        },
        "models": [
          {
            "id": "gpt-5.3-codex",
            "name": "gpt-5.3-codex",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "gpt-5.2-codex",
            "name": "gpt-5.2-codex",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "gpt-5.2",
            "name": "gpt-5.2",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 400000,
            "maxTokens": 128000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ikuncode-codex/gpt-5.3-codex"
      },
      "skipBootstrap": true,
      "models": {
        "ikuncode-codex/gpt-5.3-codex": {
          "params": {
            "maxTokens": 1024
          },
          "streaming": false
        },
        "ikuncode-codex/gpt-5.2-codex": {},
        "ikuncode-codex/gpt-5.2": {}
      },
      "workspace": "/home/suguan/openclaw-workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "memorySearch": {
        "enabled": true,
        "provider": "local",
        "model": "hf:sentence-transformers/all-MiniLM-L6-v2",
        "sync": {
          "watch": true
        }
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 6,
        "archiveAfterMinutes": 240,
        "runTimeoutSeconds": 1800
      },
      "sandbox": {
        "mode": "all",
        "workspaceAccess": "ro",
        "scope": "agent",
        "browser": {
          "allowHostControl": true
        },
        "docker": {
          "image": "openclaw-sandbox:ubuntu-24.04-full",
          "workdir": "/workspace",
          "readOnlyRoot": false,
          "network": "bridge",
          "user": "0:0",
          "env": {
            "GH_CONFIG_DIR": "/tmp/.openclaw/gh",
            "npm_config_nodedir": "/usr"
          },
          "setupCommand": "mkdir -p /tmp/.openclaw && if [ -d /agent/.openclaw/gh ] && [ ! -e /tmp/.openclaw/gh ]; then cp -a /agent/.openclaw/gh /tmp/.openclaw/gh; fi && (git config --global credential.https://github.com.helper \"!gh auth git-credential\" || true) && (sudo -n true >/dev/null 2>&1 || (printf \"#!/usr/bin/env bash\\nexec \\\"\\$@\\\"\\n\" > /usr/local/bin/sudo && chmod +x /usr/local/bin/sudo))",
          "binds": [
            "/home/suguan/github.com/ontosAI/knowhere-openclaw-plugin:/home/suguan/github.com/ontosAI/knowhere-openclaw-plugin:ro"
          ],
          "dangerouslyAllowExternalBindSources": true
        }
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Main Agent",
        "workspace": "/home/suguan/openclaw-workspace",
        "agentDir": "~/.openclaw/agents/main/agent"
      },
      {
        "id": "research-lead",
        "name": "Research Lead",
        "workspace": "~/.openclaw/workspace-research-lead",
        "agentDir": "~/.openclaw/agents/research-lead/agent",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "groupChat": {
          "mentionPatterns": [
            "@manager\b",
            "@lead\b",
            "@engineer\b",
            "@researcher\b",
            "@reporter\b",
            "@tracker\b"
          ]
        },
        "subagents": {
          "allowAgents": [
            "engineer",
            "reporter",
            "researcher",
            "tracker"
          ]
        }
      },
      {
        "id": "researcher",
        "name": "Researcher",
        "workspace": "~/.openclaw/workspace-researcher",
        "agentDir": "~/.openclaw/agents/researcher/agent",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "exec": {
            "host": "gateway"
          }
        }
      },
      {
        "id": "engineer",
        "name": "Engineer",
        "workspace": "~/.openclaw/workspace-engineer",
        "agentDir": "~/.openclaw/agents/engineer/agent",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "sandbox": {
          "mode": "all",
          "workspaceAccess": "ro",
          "scope": "agent"
        }
      },
      {
        "id": "reporter",
        "name": "Reporter",
        "workspace": "~/.openclaw/workspace-reporter",
        "agentDir": "~/.openclaw/agents/reporter/agent",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "sandbox": {
          "mode": "all",
          "workspaceAccess": "ro",
          "scope": "agent"
        }
      },
      {
        "id": "tracker",
        "name": "Tracker",
        "workspace": "~/.openclaw/workspace-tracker",
        "agentDir": "~/.openclaw/agents/tracker/agent",
        "model": "ikuncode-codex/gpt-5.3-codex",
        "sandbox": {
          "mode": "all",
          "workspaceAccess": "ro",
          "scope": "agent"
        }
      }
    ]
  },
  "tools": {
    "deny": [],
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": true
      }
    },
    "elevated": {
      "enabled": false
    },
    "exec": {
      "host": "sandbox",
      "security": "full",
      "ask": "off",
      "pathPrepend": [
        "/agent/.openclaw/bin"
      ]
    },
    "fs": {
      "workspaceOnly": false
    },
    "sandbox": {
      "tools": {
        "allow": [
          "read",
          "edit",
          "write",
          "apply_patch",
          "exec",
          "process",
          "cron",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "subagents",
          "session_status",
          "discord",
          "image",
          "group:memory",
          "browser",
          "canvas",
          "knowhere_*"
        ],
        "deny": [
          "nodes",
          "gateway",
          "telegram",
          "whatsapp",
          "irc",
          "googlechat",
          "slack",
          "signal",
          "imessage",
          "line"
        ]
      }
    }
  },
  "bindings": [
    {
      "agentId": "research-lead",
      "match": {
        "channel": "discord",
        "accountId": "manager",
        "peer": {
          "kind": "channel",
          "id": "565501941510045707"
        }
      },
      "type": "route"
    },
    {
      "agentId": "engineer",
      "match": {
        "channel": "discord",
        "accountId": "engineer",
        "peer": {
          "kind": "channel",
          "id": "565501941510045707"
        }
      },
      "type": "route"
    },
    {
      "agentId": "researcher",
      "match": {
        "channel": "discord",
        "accountId": "researcher",
        "peer": {
          "kind": "channel",
          "id": "565501941510045707"
        }
      },
      "type": "route"
    },
    {
      "agentId": "reporter",
      "match": {
        "channel": "discord",
        "accountId": "reporter",
        "peer": {
          "kind": "channel",
          "id": "565501941510045707"
        }
      },
      "type": "route"
    },
    {
      "agentId": "tracker",
      "match": {
        "channel": "discord",
        "accountId": "tracker",
        "peer": {
          "kind": "channel",
          "id": "565501941510045707"
        }
      },
      "type": "route"
    },
    {
      "agentId": "research-lead",
      "match": {
        "channel": "discord",
        "accountId": "manager",
        "peer": {
          "kind": "channel",
          "id": "1483122814025465937"
        }
      },
      "type": "route"
    },
    {
      "agentId": "researcher",
      "match": {
        "channel": "discord",
        "accountId": "researcher",
        "peer": {
          "kind": "channel",
          "id": "1483122814025465937"
        }
      },
      "type": "route"
    }
  ],
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "threadBindings": {
      "enabled": true,
      "idleHours": 72,
      "maxAgeHours": 0
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "allowFrom": [
        "476950196589428738"
      ],
      "commands": {
        "nativeSkills": true
      },
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "guilds": {
        "565501940742619145": {
          "requireMention": true,
          "ignoreOtherMentions": true,
          "channels": {
            "1483122814025465937": {
              "allow": true
            },
            "general": {
              "allow": true
            }
          }
        }
      },
      "threadBindings": {
        "enabled": true,
        "idleHours": 72,
        "maxAgeHours": 0,
        "spawnSubagentSessions": true,
        "spawnAcpSessions": true
      },
      "defaultAccount": "manager",
      "accounts": {
        "default": {
          "groupPolicy": "allowlist",
          "streaming": "off"
        },
        "manager": {
          "name": "OpenClaw Manager",
          "groupPolicy": "allowlist",
          "streaming": "off",
          "token": "${DISCORD_MANAGER_TOKEN}"
        },
        "engineer": {
          "name": "OpenClaw Engineer",
          "groupPolicy": "allowlist",
          "streaming": "off",
          "token": "${DISCORD_ENGINEER_TOKEN}"
        },
        "researcher": {
          "name": "OpenClaw Researcher",
          "groupPolicy": "allowlist",
          "streaming": "off",
          "token": "${DISCORD_RESEARCHER_TOKEN}"
        },
        "reporter": {
          "name": "OpenClaw Reporter",
          "groupPolicy": "allowlist",
          "streaming": "off",
          "token": "${DISCORD_REPORTER_TOKEN}"
        },
        "tracker": {
          "name": "OpenClaw Tracker",
          "groupPolicy": "allowlist",
          "streaming": "off",
          "token": "${DISCORD_TRACKER_TOKEN}"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "enabled": true,
      "root": "/home/suguan/.openclaw/control-ui",
      "allowedOrigins": [
        "https://oracle-phoneix.tail54f62.ts.net"
      ]
    },
    "auth": {
      "mode": "password",
      "password": "${OPENCLAW_GATEWAY_PASSWORD}"
    },
    "trustedProxies": [
      "127.0.0.1",
      "::1"
    ],
    "tailscale": {
      "mode": "serve",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "pnpm"
    }
  },
  "plugins": {
    "allow": [
      "acpx",
      "knowhere-claw"
    ],
    "load": {
      "paths": [
        "/home/suguan/github.com/ontosAI/knowhere-openclaw-plugin"
      ]
    },
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "command": "acpx",
          "expectedVersion": "0.1.16",
          "cwd": "/home/suguan/openclaw-workspace",
          "permissionMode": "approve-all",
          "nonInteractivePermissions": "fail",
          "mcpServers": {
            "logfire": {
              "command": "bash",
              "args": [
                "-lc",
                "exec mcp-remote https://logfire-us.pydantic.dev/mcp --header \"Authorization: Bearer $LOGFIRE_READ_TOKEN\""
              ],
              "env": {
                "LOGFIRE_READ_TOKEN": "${LOGFIRE_READ_TOKEN}"
              }
            }
          }
        }
      },
      "knowhere-claw": {
        "enabled": true,
        "config": {
          "storageDir": "/home/suguan/.openclaw/plugin-state/knowhere",
          "scopeMode": "session"
        }
      },
      "open-prose": {
        "enabled": true
      }
    }
  }
}
