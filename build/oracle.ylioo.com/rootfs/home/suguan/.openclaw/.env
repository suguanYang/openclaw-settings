# Repo-safe generated .env for the build mirror
# Host: oracle.ylioo.com
# Profile source: profiles/oracle.ylioo.com.env
# Secrets source: managed/secrets.example.env
# Variable names and paths match the host layout, but secret values stay blank in git.
# Non-secret Oracle deployment profile.
# Copy to profiles/<new-host>.env and adjust paths, IDs, and origins for the target server.

OPENCLAW_HOST_USER=suguan
OPENCLAW_WORKSPACE_ROOT=/home/suguan/openclaw-workspace
