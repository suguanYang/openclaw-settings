OPENCLAW_GH_CONFIG_BIND_ROOT=/home/suguan/.openclaw/workspace-engineer/.openclaw/gh
OPENCLAW_GH_BIN_HOST_PATH=/home/suguan/.openclaw/workspace-engineer/.openclaw/bin/gh
OPENCLAW_BROWSER_EXECUTABLE_PATH=/home/suguan/.openclaw/tools/playwright-browsers/chromium-1208/chrome-linux/chrome
OPENCLAW_CONTROL_UI_ROOT=/home/suguan/.openclaw/control-ui
OPENCLAW_CONTROL_UI_ALLOWED_ORIGIN=https://oracle-phoneix.tail54f62.ts.net
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_DISCORD_GUILD_ID=565501940742619145
OPENCLAW_DISCORD_CHANNEL_ID=565501941510045707
OPENCLAW_DISCORD_CHANNEL_NAME=general
OPENCLAW_DISCORD_OWNER_USER_ID=476950196589428738
ANTHROPIC_BASE_URL=https://api.ikuncode.cc/v1
OPENAI_BASE_URL=https://api.ikuncode.cc/v1
ANTHROPIC_USER_AGENT='claude-cli/2.0.76 (external, cli)'

# Copy this file to .secrets/<host>.env and fill in the secret values.
# Do not commit the filled file.

ANTHROPIC_API_KEY=
