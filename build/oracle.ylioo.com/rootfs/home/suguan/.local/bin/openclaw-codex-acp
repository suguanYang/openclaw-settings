#!/usr/bin/env bash
set -euo pipefail

image="${OPENCLAW_CODEX_ACP_IMAGE:-openclaw-codex-acp:ubuntu-24.04}"
seed_codex_dir="${HOME}/.codex"
workdir="$(pwd -P)"
container_home="/codex-home"

if ! command -v docker >/dev/null 2>&1; then
  echo "docker is required for openclaw-codex-acp" >&2
  exit 1
fi

if [ ! -f "${seed_codex_dir}/config.toml" ]; then
  echo "missing Codex config: ${seed_codex_dir}/config.toml" >&2
  exit 1
fi

exec docker run --rm -i \
  --user "$(id -u):$(id -g)" \
  -e HOME="${container_home}" \
  -e OPENAI_API_KEY \
  -e OPENAI_BASE_URL \
  -e CODEX_API_KEY \
  -v "${seed_codex_dir}:/seed-codex:ro" \
  -v "${workdir}:${workdir}" \
  -w "${workdir}" \
  "${image}" \
  bash -lc 'set -euo pipefail; mkdir -p "$HOME/.codex"; cp /seed-codex/config.toml "$HOME/.codex/config.toml"; exec codex-acp "$@"' \
  bash \
  "$@"
